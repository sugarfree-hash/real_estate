# =========================
# Python / Django
# =========================
# コンパイル済みのキャッシュファイル
__pycache__/
*.pyc

# 仮想環境のフォルダ（ご自身の環境に合わせて myenv を指定）
myenv/
venv/
env/

# ローカルの開発用データベース（今回はGitで管理せず、各環境で作るのが一般的です）
db.sqlite3

# =========================
# Java / Eclipse
# =========================
# コンパイル済みのクラスファイルが入るフォルダ
bin/

# Eclipseのローカル設定ファイル
.settings/
.classpath
.project

# =========================
# アプリケーションの出力ファイル
# =========================
# Javaが都度生成するJSONファイルも、実行すれば作れるのでGitには含めません
dummy_estate_data.json

# =========================
# OSのシステムファイル
# =========================
.DS_Store
Thumbs.db